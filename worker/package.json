{
  "name": "masako-discord-dashboard-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --test-scheduled --ip 127.0.0.1 --port 8787",
    "health": "curl http://127.0.0.1:8787/healthz",
    "preview": "curl http://127.0.0.1:8787/",
    "debug": "curl http://127.0.0.1:8787/debug",
    "local-help": "curl http://127.0.0.1:8787/local-help",
    "scheduled": "curl \"http://127.0.0.1:8787/__scheduled?cron=*/5+*+*+*+*\"",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.84.1"
  }
}
